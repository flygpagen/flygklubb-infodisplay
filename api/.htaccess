# API directory security

Options -Indexes

# ----------------------------------------------------------------------
# Force PHP handler for .php files.
# Protects against source-code disclosure if PHP is temporarily disabled
# or misconfigured (server would otherwise serve raw .php as text).
# ----------------------------------------------------------------------
<FilesMatch "\.php$">
    <IfModule mod_mime.c>
        AddType application/x-httpd-php .php
    </IfModule>
    SetHandler application/x-httpd-php
</FilesMatch>

# ----------------------------------------------------------------------
# Deny direct access to private config files.
# config.php holds API keys and must never be served, even if PHP fails.
# config.example.php is a template and should not be public either.
# ----------------------------------------------------------------------
<FilesMatch "^(config|config\.example|config\.local|config\.backup|secrets|credentials)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ----------------------------------------------------------------------
# Block backup, swap, log, dotfiles and other sensitive variants.
# ----------------------------------------------------------------------
<FilesMatch "(^\.|\.(bak|save|swp|swo|log|env|sql|ini|example|old|orig|dist|inc|conf|cfg|tmp)$|~$)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ----------------------------------------------------------------------
# Security headers for API responses
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "no-referrer"
    # Do not allow API responses to be embedded in frames
    Header set X-Frame-Options "DENY"
</IfModule>